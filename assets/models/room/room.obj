o Room
mtllib room.mtl
s off

# Vertices (room without ceiling)
v -5.0 0.0 -5.0  
v  5.0 0.0 -5.0  
v  5.0 0.0  5.0  
v -5.0 0.0  5.0  
v -5.0 3.0 -5.0  
v  5.0 3.0 -5.0  
v  5.0 3.0  5.0  
v -5.0 3.0  5.0  

# Texture coordinates (tiled)
# Floor (tiles 4x4)
vt 0.0 0.0   
vt 4.0 0.0   
vt 4.0 4.0   
vt 0.0 4.0   

# Wall -Z (tiles 3x2)
vt 0.0 0.0   
vt 3.0 0.0   
vt 3.0 2.0   
vt 0.0 2.0   

# Wall +X (tiles 3x2)
vt 0.0 0.0   
vt 3.0 0.0   
vt 3.0 2.0   
vt 0.0 2.0   

# Wall +Z (tiles 3x2)
vt 0.0 0.0   
vt 3.0 0.0
vt 3.0 2.0
vt 0.0 2.0

# Wall -X (tiles 3x2)
vt 0.0 0.0   
vt 3.0 0.0 
vt 3.0 2.0 
vt 0.0 2.0 

# Texture coordinates Ceiling (tiles 4x4)
vt 0.0 0.0
vt 4.0 0.0
vt 4.0 4.0
vt 0.0 4.0

# Normals (point inward so room is visible from inside)
vn  0.0  1.0  0.0 
vn  0.0  0.0  1.0  
vn -1.0  0.0  0.0  
vn  0.0  0.0 -1.0  
vn  1.0  0.0  0.0  

# Normal for ceiling (pointing down)
vn  0.0 -1.0  0.0

g Floor
usemtl Floor
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

g Wall_NegZ
usemtl Wall
# Triangles ordered CCW as seen from inside (inward normal +Z)
f 5/8/2 2/6/2 6/7/2
f 5/8/2 1/5/2 2/6/2

g Wall_PosX
usemtl Wall
# Inward normal -X
f 6/12/3 3/10/3 7/11/3
f 6/12/3 2/9/3 3/10/3

g Wall_PosZ
usemtl Wall
# Inward normal -Z
f 7/16/4 4/14/4 8/15/4
f 7/16/4 3/13/4 4/14/4

g Wall_NegX
usemtl Wall
# Inward normal +X
f 8/20/5 1/18/5 5/19/5
f 8/20/5 4/17/5 1/18/5

g Ceiling
usemtl Ceiling
# CCW from inside (normal -Y)
f 5/21/6 6/22/6 7/23/6
f 5/21/6 7/23/6 8/24/6
